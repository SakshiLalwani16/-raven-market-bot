# --- Telegram ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Channel username (@channel) or numeric ID (-100xxxxxxxxxx)
CHANNEL_ID=@raven_market_alerts

# --- On-chain (Canton Chain / EVM-compatible) ---
# Your Canton Chain JSON-RPC endpoint
RPC_URL=https://your-canton-rpc-endpoint

# Deployed settlement contract address
CONTRACT_ADDRESS=0xYourSettlementContractAddress

# --- REST API (optional, used if contract calls are not configured) ---
SETTLEMENT_API_URL=https://api.ravenmarket.io/v1/settlement/latest

# --- Scheduler ---
# Cron expression for how often to poll (default: every 5 minutes)
CRON_EXPRESSION=*/5 * * * *
